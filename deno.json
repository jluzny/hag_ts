{
  "compilerOptions": {
    "strict": true,
    "lib": [
      "dom",
      "deno.ns",
      "esnext"
    ]
  },
  "imports": {
    "@needle-di/core": "npm:@needle-di/core@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/log": "jsr:@std/log@^0.224.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/http": "jsr:@std/http@^1.0.0",
    "@std/collections": "jsr:@std/collections@^1.0.0",
    "@cliffy/command": "https://deno.land/x/cliffy@v0.25.7/command/mod.ts",
    "xstate": "npm:xstate@^5.20.0",
    "@langchain/core": "npm:@langchain/core@^0.3.61",
    "@langchain/openai": "npm:@langchain/openai@^0.5.16",
    "langchain": "npm:langchain@^0.3.29",
    "zod": "npm:zod@^3.25.67",
    "yaml": "npm:yaml@^2.8.0"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --allow-write src/main.ts",
    "dev:watch": "deno run --watch --allow-net --allow-read --allow-env --allow-write src/main.ts",
    "test": "deno test --allow-net --allow-read --allow-env --allow-write tests/",
    "test:unit": "deno test --allow-net --allow-read --allow-env --allow-write tests/unit/",
    "test:integration": "deno test --allow-net --allow-read --allow-env --allow-write tests/integration/",
    "test:watch": "deno test --allow-net --allow-read --allow-env --allow-write --watch tests/",
    "test:coverage": "deno test --allow-net --allow-read --allow-env --allow-write --coverage=coverage tests/",
    "build": "deno compile --allow-net --allow-read --allow-env --allow-write --no-check -o hag src/main.ts",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "exclude": [
    "node_modules",
    ".git"
  ]
}
