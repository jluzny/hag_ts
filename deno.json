{
  "compilerOptions": {
    "strict": true,
    "lib": [
      "dom",
      "deno.ns",
      "esnext"
    ]
  },
  "imports": {
    "@needle-di/core": "jsr:@needle-di/core@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.14",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/log": "jsr:@std/log@^0.224.14",
    "@std/fmt": "jsr:@std/fmt@^1.0.8",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/path": "jsr:@std/path@^1.1.0",
    "@std/async": "jsr:@std/async@^1.0.13",
    "@std/http": "jsr:@std/http@^1.0.18",
    "@std/collections": "jsr:@std/collections@^1.1.1",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7",
    "@std/yaml": "jsr:@std/yaml@^1.0.8",
    "xstate": "npm:xstate@^5.20.0",
    "@langchain/core": "npm:@langchain/core@^0.3.61",
    "@langchain/openai": "npm:@langchain/openai@^0.5.16",
    "langchain": "npm:langchain@^0.3.29",
    "zod": "npm:zod@^3.25.67"
  },
  "tasks": {
    "dev": "deno run -A src/main.ts --",
    "dev:watch": "deno run --watch -A src/main.ts --",
    "test": "deno test -A tests/",
    "test:unit": "deno test -A tests/unit/",
    "test:integration": "deno test -A tests/integration/",
    "test:watch": "deno test -A --watch tests/",
    "test:coverage": "deno test -A --coverage=coverage tests/",
    "build": "deno compile -A --no-check -o hag src/main.ts && mkdir -p target && cp hag target/hag && cp config/hvac_config.yaml target/hvac_config.yaml && rm hag",
    "build:musl": "deno compile --target x86_64-unknown-linux-musl -A --no-check -o hag src/main.ts && mkdir -p target && cp hag target/hag && cp config/hvac_config.yaml target/hvac_config.yaml && rm hag",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "exclude": [
    "node_modules",
    ".git"
  ]
}
